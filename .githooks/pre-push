set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

echo "[eter] Running pre-push checks..."

if [[ ! -f build/build.ninja ]]; then
  echo "[eter] error: build directory is not configured." >&2
  echo "[eter] Run: cmake -S . -B build -G Ninja" >&2
  exit 1
fi

echo "[eter] Building project..."
cmake --build build

echo "[eter] Running test suite..."
cmake --build build --target check-eter

echo "[eter] Pre-push checks passed."
